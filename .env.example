# Copy to .env. Never commit real credentials.
CODEBASE_INTEL_ENVIRONMENT=development
CODEBASE_INTEL_LOG_LEVEL=INFO
CODEBASE_INTEL_DATA_DIR=.data
CODEBASE_INTEL_API_HOST=127.0.0.1
CODEBASE_INTEL_API_PORT=8000
CODEBASE_INTEL_API_BASE_URL=http://127.0.0.1:8000
CODEBASE_INTEL_UI_HOST=127.0.0.1
CODEBASE_INTEL_UI_PORT=8501

# Voyage is code-specialized. Set to openai or deterministic as needed.
CODEBASE_INTEL_EMBEDDING_PROVIDER=voyage
CODEBASE_INTEL_VOYAGE_EMBEDDING_MODEL=voyage-code-3
CODEBASE_INTEL_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
VOYAGE_API_KEY=
OPENAI_API_KEY=

# OpenAI produces a synthesized explanation. Extractive mode needs no chat credential.
CODEBASE_INTEL_ANSWER_PROVIDER=openai
CODEBASE_INTEL_OPENAI_CHAT_MODEL=gpt-5-mini

# Embedded Qdrant is for one-process local use. Set QDRANT_URL for API + worker deployments.
CODEBASE_INTEL_QDRANT_URL=
CODEBASE_INTEL_QDRANT_API_KEY=
CODEBASE_INTEL_QDRANT_COLLECTION_PREFIX=codebase_intel

# Optional shared API key. Leave blank for loopback-only development.
CODEBASE_INTEL_API_KEY=
CODEBASE_INTEL_ALLOWED_ORIGINS=["http://127.0.0.1:8501","http://localhost:8501"]
CODEBASE_INTEL_INLINE_WORKER=true
